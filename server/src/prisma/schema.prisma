// schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum ActuatorStatus {
  VERYLOW
  LOW
  NORMAL
  HIGH
  VERYHIGH
}

enum ActuatorType {
  pump
  fan
  humidifier
}

enum Mode {
  Fuzzy
  Timer
  Manual
}

model Data {
  id           String         @id @default(uuid())
  date         DateTime
  temperature  Float
  humidity     Float
  soil         Float
  pump         ActuatorStatus
  fan          ActuatorStatus
  humidifier   ActuatorStatus
  actuatorLogs ActuatorLog[]

  @@map("data")
}

model ActuatorLog {
  id     String         @id @default(uuid())
  date   DateTime       @default(now())
  type   ActuatorType
  status ActuatorStatus
  mode   Mode
  dataId String?
  data   Data?          @relation(fields: [dataId], references: [id])

  @@map("actuator_log")
}

model ActuatorLock {
  id        String   @id @default(uuid())
  type      ActuatorType @unique
  locked    Boolean  @default(false)
  updatedAt DateTime @updatedAt
  @@map("actuator_lock")
}