generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum ActuatorStatus {
  VERYLOW
  LOW
  NORMAL
  HIGH
  VERYHIGH
}

enum ActuatorType {
  pump
  fan
  humidifier
}

enum Mode {
  Fuzzy
  Timer
  Manual
}

model Data {
  id BigInt @id @default(autoincrement())

  recordedAt DateTime @default(now())

  temperature Float
  humidity    Float
  soil        Float

  pump       ActuatorStatus
  fan        ActuatorStatus
  humidifier ActuatorStatus

  mode Mode @default(Fuzzy)

  @@index([recordedAt])
  @@index([recordedAt, id])
  @@map("data")
}

model ActuatorLog {
  id BigInt @id @default(autoincrement())

  recordedAt DateTime @default(now())

  type   ActuatorType
  status ActuatorStatus
  mode   Mode

  // snapshot kondisi sensor saat log dibuat
  temperature Float?
  humidity    Float?
  soil        Float?

  @@index([recordedAt])
  @@index([type, recordedAt])
  @@index([mode, recordedAt])

  @@map("actuator_log")
}

model ActuatorLock {
  type      ActuatorType @id
  locked    Boolean      @default(false)
  updatedAt DateTime     @updatedAt

  @@map("actuator_lock")
}